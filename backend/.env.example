APP_NAME=智友后台服务
APP_VERSION=0.1.0
ENVIRONMENT=development
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://127.0.0.1:5124,http://localhost:5124,http://127.0.0.1:5123,http://localhost:5123
# 开发环境默认额外允许 localhost、127.0.0.1 和私有局域网来源。
# 生产环境请设置明确域名；如确需正则可配置 ALLOWED_ORIGIN_REGEX。
ALLOWED_ORIGIN_REGEX=

# 本地不填 DATABASE_URL 时会自动使用 backend/zhiyou_dev.db。
# 1Panel PostgreSQL 推荐使用 psycopg 驱动。
DATABASE_URL=postgresql+psycopg://zhiyou:password@127.0.0.1:5432/zhiyou
REDIS_URL=redis://127.0.0.1:6379/0

# OpenAI 垂钓分析。真实 Key 只放 backend/.env 或系统环境变量，不能提交到 GitHub。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
